{
  "expo": {
    "name": "MotoTwin",
    "slug": "mototwin-app",
    "scheme": "mototwin",
    "version": "0.1.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router"
    ],
    "ios": {
      "bundleIdentifier": "com.anonymous.mototwin-app"
    }
  }
}
