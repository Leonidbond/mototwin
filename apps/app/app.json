{
  "expo": {
    "name": "MotoTwin",
    "slug": "mototwin",
    "scheme": "mototwin",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080D12"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-apple-authentication"
    ],
    "android": {
      "package": "ru.mototwin.app",
      "versionCode": 1,
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "mototwin.space",
              "pathPrefix": "/oauth"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080D12"
      }
    },
    "ios": {
      "bundleIdentifier": "ru.mototwin.app",
      "usesAppleSignIn": true,
      "associatedDomains": ["applinks:mototwin.space"]
    },
    "extra": {
      "eas": {
        "projectId": "9bd6ab62-91aa-4298-b3cd-d9a78e2ff53a"
      }
    }
  }
}
