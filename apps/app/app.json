{
  "expo": {
    "name": "MotoTwin",
    "slug": "mototwin-app",
    "scheme": "mototwin",
    "version": "0.1.0",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      "expo-apple-authentication"
    ],
    "android": {
      "package": "ru.mototwin.app"
    },
    "ios": {
      "bundleIdentifier": "ru.mototwin.app",
      "usesAppleSignIn": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_AFTER_eas_init"
      }
    }
  }
}
