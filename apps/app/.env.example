# Copy to .env and adjust. File .env is gitignored.
#
# When Metro uses a tunnel (npm run mobile:dev:tunnel), the packager host (*.exp.direct)
# only reaches port 8081 — not your Next.js API on :3000. The app then MUST use a URL
# your phone can open: the LAN IP of the Mac/PC where `npm run dev` runs (port 3000).
#
# Mac: System Settings → Network → Wi-Fi → Details → IP Address
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000
