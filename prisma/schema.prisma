/**
 * Append-only journal of mutating admin actions for traceability and rollbacks.
 * Populated via `logAdminAction()` from `src/lib/admin-audit.ts`.
 */
model AdminAuditLog {
  id            String   @id @default(cuid())
  actorId       String
  actor         User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  /** Stable dot-namespaced action id, e.g. "fitment.publish", "support.change". */
  action        String
  /** Prisma model name, e.g. "PartMaster", "FitmentReport", "ModelVariant". */
  entityType    String
  entityId      String
  before        Json?
  after         Json?
  reason        String?
  importBatchId String?
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([importBatchId])
  @@map("admin_audit_logs")
}

/**
 * Single bulk-upload session. The 8-step import wizard (см. spec §9) carries
 * its state on this row; raw rows live on {@link ImportBatchRow}.
 */
model ImportBatch {
  id           String            @id @default(cuid())
  type         ImportBatchType
  status       ImportBatchStatus @default(DRAFT)
  fileName     String
  fileUrl      String?
  createdById  String
  createdBy    User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  /** Mapping of source columns to canonical fields, set on step 3. */
  mapping      Json?
  /** Aggregated counters: { created, updated, skipped, conflicts, errors }. */
  summary      Json?
  dryRunAt     DateTime?
  committedAt  DateTime?
  rolledBackAt DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  rows ImportBatchRow[]

  @@index([type, status])
  @@index([createdById, createdAt])
  @@map("import_batches")
}

model ImportBatchRow {
  id             String   @id @default(cuid())
  batchId        String
  batch          ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rowIndex       Int
  raw            Json
  /** "create" | "update" | "skip" | "conflict" — set after validation. */
  action         String?
  /** "ok" | "warning" | "error". */
  status         String   @default("ok")
  errorMessage   String?
  /** ID of the entity created/updated by this row, if any. */
  mappedEntityId String?

  @@index([batchId, rowIndex])
  @@index([batchId, status])
  @@map("import_batch_rows")
}

/**
 * Alternative SKU/article spellings for {@link PartMaster}. Used by duplicate
 * search and OEM cross-reference flows in the admin panel.
 */
model PartAlias {
  id           String     @id @default(cuid())
  partMasterId String
  partMaster   PartMaster @relation(fields: [partMasterId], references: [id], onDelete: Cascade)
  alias        String
  normalized   String
  /** "import" | "admin" | "user". */
  source       String?
  createdAt    DateTime   @default(now())

  @@unique([partMasterId, normalized])
  @@index([partMasterId])
  @@index([normalized])
  @@map("part_aliases")
}
