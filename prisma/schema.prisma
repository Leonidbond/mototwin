generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  TRIAL
}

enum UsageType {
  CITY
  HIGHWAY
  MIXED
  OFFROAD
}

enum RidingStyle {
  CALM
  ACTIVE
  AGGRESSIVE
}

enum LoadType {
  SOLO
  PASSENGER
  LUGGAGE
  PASSENGER_LUGGAGE
}

enum UsageIntensity {
  LOW
  MEDIUM
  HIGH
}

enum TopNodeStatus {
  OK
  SOON
  OVERDUE
  RECENTLY_REPLACED
}

enum NodeStatus {
  OK
  SOON
  OVERDUE
  RECENTLY_REPLACED
}

enum MaintenanceTriggerMode {
  WHICHEVER_COMES_FIRST
  ANY
  ALL
}

enum ServiceEventKind {
  SERVICE
  STATE_UPDATE
}

enum ServiceEventMode {
  BASIC
  ADVANCED
}

/** Кто выполнил сервисное событие (форма «Исполнитель»). */
enum ServicePerformedBy {
  SELF
  SERVICE
  OTHER
}

enum ServiceActionType {
  REPLACE
  SERVICE
  INSPECT
  CLEAN
  ADJUST
}

enum PartWishlistItemStatus {
  NEEDED
  ORDERED
  BOUGHT
  INSTALLED
  REJECTED
}

enum PartWishlistItemSource {
  RECOMMENDATION
  USER_ADDED
}

enum PartMasterSource {
  ADMIN
  USER
}

enum PartMasterStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  MERGED
  REJECTED
}

enum FitmentReportResult {
  DIRECT_FIT
  FIT_WITH_MODIFICATION
  PARTIAL_FIT
  DOES_NOT_FIT
  OEM_REPLACEMENT
}

enum FitmentInstallationStatus {
  INSTALLED
  PURCHASED_NOT_INSTALLED
  TESTED_NOT_INSTALLED
}

enum FitmentReportModerationStatus {
  PENDING
  PUBLISHED
  NEEDS_REVIEW
  HIDDEN
  REJECTED
}

enum FitmentEvidenceType {
  PART_PHOTO
  PACKAGING_PHOTO
  INSTALLED_PHOTO
  RECEIPT
  SERVICE_EVENT
}

enum FitmentVoteType {
  CONFIRM
  REJECT
  SAME_EXPERIENCE
  DIFFERENT_EXPERIENCE
  HELPFUL
}

enum FitmentConfidenceStatus {
  VERIFIED_BY_MOTOTWIN
  COMMUNITY_CONFIRMED
  FITS_WITH_MODIFICATION
  MIXED_REPORTS
  LOW_CONFIDENCE
  REJECTED_LIKELY_INCOMPATIBLE
}

enum ExpenseCategory {
  PART
  CONSUMABLE
  SERVICE_WORK
  REPAIR
  DIAGNOSTICS
  OTHER
}

enum ExpenseInstallStatus {
  BOUGHT_NOT_INSTALLED
  INSTALLED
  NOT_APPLICABLE
}

enum ExpensePurchaseStatus {
  PLANNED
  PURCHASED
}

enum ExpenseInstallationStatus {
  NOT_INSTALLED
  INSTALLED
}

enum NotificationType {
  SERVICE_OVERDUE
  SERVICE_UPCOMING
  MILEAGE_UPDATE_REQUIRED
  ENGINE_HOURS_UPDATE_REQUIRED
  MISSING_SERVICE_DATA
  WEEKLY_DIGEST
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

enum NotificationStatus {
  NEW
  SEEN
  READ
  SNOOZED
  RESOLVED
  DISMISSED
  EXPIRED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH_WEB
  PUSH_MOBILE
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
  MUTED
  RATE_LIMITED
}

enum PushChannelType {
  WEB_PUSH
  MOBILE_PUSH
}

enum PushProvider {
  WEBPUSH
  EXPO
  FCM
  APNS
}

enum PushPlatform {
  WEB
  IOS
  ANDROID
}

enum UsageUpdateSource {
  MANUAL
  SERVICE_EVENT
  IMPORT
  TELEMETRY
}

enum AdminRole {
  SUPER_ADMIN
  CATALOG_MANAGER
  MODERATOR
  ANALYST
}

enum ModelSupportLevel {
  FULL_SUPPORT
  COMMUNITY_SUPPORT
  EARLY_BETA
  NO_DATA
  UNSUPPORTED
}

enum ImportBatchType {
  PARTS
  FITMENT_RULES
  SERVICE_RULES
  MODELS
  CONFIGURATIONS
  OEM_CROSS
  PART_ALIASES
}

enum ImportBatchStatus {
  DRAFT
  VALIDATING
  READY
  IMPORTING
  COMMITTED
  ROLLED_BACK
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  displayName  String?
  passwordHash String?
  isBlocked    Boolean  @default(false)
  blockedAt    DateTime?
  blockReason  String?
  /** Moderation UI for community fitment and PartMaster review. */
  isModerator Boolean  @default(false)
  /** Primary RBAC source for the admin panel; null = no admin access. */
  adminRole   AdminRole?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscription Subscription?
  settings     UserSettings?
  notificationSettings UserNotificationSettings?
  vehicleNotificationSettings VehicleNotificationSettings[]
  vehicles     Vehicle[]
  garages      Garage[]
  serviceEventFormTemplates UserServiceEventFormTemplate[]
  notifications            Notification[]
  pushSubscriptions        PushSubscription[]
  mileageHoursUpdateLogs   MileageHoursUpdateLog[]
  partMastersCreated        PartMaster[]        @relation("PartMasterCreatedBy")
  fitmentReportsCreated     FitmentReport[]     @relation("FitmentReportCreatedBy")
  fitmentVotes              FitmentVote[]
  adminAuditLogs            AdminAuditLog[]
  importBatches             ImportBatch[]
  authSessions              AuthSession[]
  refreshTokens             RefreshToken[]
  accounts                  Account[]
  sessions                  Session[]
  passwordResetTokens       PasswordResetToken[]

  @@index([adminRole])
  @@index([isBlocked])
  @@map("users")
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("authjs_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

enum AuthSessionKind {
  WEB
  ACCESS
}

model AuthSession {
  id        String          @id @default(cuid())
  userId    String
  kind      AuthSessionKind
  tokenHash String          @unique
  expiresAt DateTime
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model UserServiceEventFormTemplate {
  id        String   @id @default(cuid())
  userId    String
  title     String
  mode      String
  formJson  Json
  /** When true, комплект из этого шаблона показывается в подборе деталей. */
  includeInPartPicker Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_service_event_form_templates")
}

model UserSettings {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  defaultCurrency           String   @default("RUB")
  distanceUnit              String   @default("km")
  engineHoursUnit           String   @default("h")
  dateFormat                String   @default("DD.MM.YYYY")
  defaultSnoozeDays         Int      @default(7)
  vehicleTrashRetentionDays Int      @default(30)
  favoriteNodeCodes         String[] @default([])
  defaultNodeView           String   @default("top")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Garage {
  id          String   @id @default(cuid())
  ownerUserId String
  title       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerUser User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  vehicles  Vehicle[]

  @@unique([ownerUserId, title])
  @@index([ownerUserId])
  @@map("garages")
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String             @unique
  planType  PlanType           @default(FREE)
  status    SubscriptionStatus @default(ACTIVE)
  startedAt DateTime           @default(now())
  endsAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  models   Model[]
  vehicles Vehicle[]

  @@map("brands")
}

model Model {
  id        String   @id @default(cuid())
  brandId   String
  name      String
  slug      String
  createdAt DateTime @default(now())

  brand    Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  variants ModelVariant[]
  vehicles Vehicle[]

  @@unique([brandId, slug])
  @@map("models")
}

model ModelVariant {
  id             String   @id @default(cuid())
  modelId        String
  year           Int
  generation     String?
  versionName    String
  market         String?
  engineType     String?
  coolingType    String?
  wheelSizes     String?
  brakeSystem    String?
  chainPitch     String?
  stockSprockets String?
  /** Admin override; when null, support level is inferred from data. */
  supportLevel   ModelSupportLevel?
  /** Last reason captured when support level was changed by an admin. */
  supportLevelReason String?
  createdAt      DateTime @default(now())

  model    Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]
  fitmentConfidences FitmentConfidence[]
  fitmentReports     FitmentReport[]

  @@index([modelId, year])
  @@map("model_variants")
}

model Vehicle {
  id             String    @id @default(cuid())
  userId         String
  garageId       String?
  trashedAt      DateTime?
  trashExpiresAt DateTime?
  brandId        String
  modelId        String
  modelVariantId String
  nickname       String?
  vin            String?
  odometer       Int       @default(0)
  engineHours    Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  garage            Garage?            @relation(fields: [garageId], references: [id], onDelete: SetNull)
  brand             Brand              @relation(fields: [brandId], references: [id], onDelete: Restrict)
  model             Model              @relation(fields: [modelId], references: [id], onDelete: Restrict)
  modelVariant      ModelVariant       @relation(fields: [modelVariantId], references: [id], onDelete: Restrict)
  rideProfile       RideProfile?
  serviceEvents     ServiceEvent[]
  topNodeStates     TopNodeState[]
  nodeStates        NodeState[]
  notifications     Notification[]
  notificationSettings VehicleNotificationSettings?
  mileageHoursUpdateLogs MileageHoursUpdateLog[]
  partWishlistItems PartWishlistItem[]
  expenseItems      ExpenseItem[]
  fitmentReports    FitmentReport[]

  @@index([userId])
  @@index([garageId])
  @@index([trashedAt])
  @@index([trashExpiresAt])
  @@index([garageId, trashedAt])
  @@index([garageId, userId])
  @@index([brandId, modelId, modelVariantId])
  @@map("vehicles")
}

model ServiceEvent {
  id                 String           @id @default(cuid())
  vehicleId          String
  /**
   * Anchor leaf node — represents the primary affected node and remains for filter/sort/back-compat.
   */
  nodeId             String
  eventKind          ServiceEventKind @default(SERVICE)
  /**
   * Bundle mode: BASIC = single common action across multiple nodes; ADVANCED = per-item details.
   */
  mode               ServiceEventMode @default(BASIC)
  /**
   * Bundle title (free-form), e.g. «ТО 10 000 км».
   */
  title              String?
  eventDate          DateTime
  odometer           Int
  engineHours        Int?
  installedPartsJson Json?
  /**
   * Sum of parts costs across all bundle items (or manual top-level entry in BASIC mode).
   */
  partsCost          Decimal?         @db.Decimal(12, 2)
  /**
   * Sum of labor costs across all bundle items (or manual top-level entry in BASIC mode).
   */
  laborCost          Decimal?         @db.Decimal(12, 2)
  /**
   * partsCost + laborCost; canonical bundle total (replaces legacy `costAmount`).
   */
  totalCost          Decimal?         @db.Decimal(12, 2)
  currency           String?
  comment            String?
  performedBy               ServicePerformedBy?
  serviceProviderNote       String?
  installLocationAddress    String?
  installLocationLat        Float?
  installLocationLng        Float?
  attachReceiptRequested    Boolean          @default(false)
  attachFileRequested       Boolean          @default(false)
  nextReminderEnabled       Boolean          @default(false)
  nextReminderDate          DateTime?
  nextReminderOdometer      Int?
  nextReminderEngineHours   Int?
  createdAt          DateTime         @default(now())

  vehicle      Vehicle            @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  node         Node               @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  items        ServiceEventItem[]
  expenseItems ExpenseItem[]
  fitmentReports FitmentReport[]

  @@index([vehicleId])
  @@index([nodeId])
  @@map("service_events")
}

/**
 * One affected node within a Service Bundle event. At least one row per ServiceEvent.
 */
model ServiceEventItem {
  id             String            @id @default(cuid())
  serviceEventId String
  nodeId         String
  actionType     ServiceActionType @default(SERVICE)
  /**
   * Optional in BASIC, freely entered in ADVANCED.
   */
  partName       String?
  /**
   * Optional SKU/article in ADVANCED.
   */
  sku            String?
  /**
   * Optional quantity in ADVANCED.
   */
  quantity       Int?
  /**
   * Per-item parts cost in ADVANCED; null in BASIC (totals live on event).
   */
  partCost       Decimal?          @db.Decimal(12, 2)
  /**
   * Per-item labor cost in ADVANCED; null in BASIC.
   */
  laborCost      Decimal?          @db.Decimal(12, 2)
  comment        String?
  /**
   * Stable order for UI rendering (also used for synthesis of legacy single-row view).
   */
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  serviceEvent ServiceEvent @relation(fields: [serviceEventId], references: [id], onDelete: Cascade)
  node         Node         @relation(fields: [nodeId], references: [id], onDelete: Restrict)

  @@index([serviceEventId])
  @@index([nodeId])
  @@map("service_event_items")
}

model Node {
  id                       String   @id @default(cuid())
  code                     String   @unique
  name                     String
  parentId                 String?
  level                    Int
  displayOrder             Int
  isActive                 Boolean  @default(true)
  isServiceRelevant        Boolean  @default(true)
  isMvpVisible             Boolean  @default(false)
  isAdvanced               Boolean  @default(false)
  isTopNode                Boolean  @default(false)
  topNodeOrder             Int?
  serviceGroup             String?
  defaultServiceOperations String[] @default([])
  createdAt                DateTime @default(now())

  parent            Node?                @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Node[]               @relation("NodeHierarchy")
  serviceEvents     ServiceEvent[]
  serviceEventItems ServiceEventItem[]
  topNodeStates     TopNodeState[]
  nodeStates        NodeState[]
  maintenanceRule   NodeMaintenanceRule?
  notifications     Notification[]
  partWishlistItems PartWishlistItem[]
  expenseItems      ExpenseItem[]
  partSkusPrimary   PartSku[]            @relation("PartSkuPrimaryNode")
  partSkuNodeLinks              PartSkuNodeLink[]
  serviceBundleTemplateItems    ServiceBundleTemplateItem[]
  fitmentConfidences            FitmentConfidence[]
  fitmentReports                FitmentReport[]

  @@index([parentId])
  @@map("nodes")
}

model ServiceBundleTemplate {
  id                String   @id @default(cuid())
  title             String
  description       String?
  category          String?
  isRegulationBased Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  items ServiceBundleTemplateItem[]

  @@map("service_bundle_templates")
}

model ServiceBundleTemplateItem {
  id                String            @id @default(cuid())
  templateId        String
  nodeId            String
  defaultActionType ServiceActionType @default(SERVICE)
  isRequired        Boolean           @default(true)
  sortOrder         Int               @default(0)

  template ServiceBundleTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  node     Node                  @relation(fields: [nodeId], references: [id], onDelete: Restrict)

  @@index([templateId])
  @@index([nodeId])
  @@map("service_bundle_template_items")
}

/**
 * Global part identity (user-submitted or admin). Catalog rows {@link PartSku} reference one master.
 */
model PartMaster {
  id               String           @id @default(cuid())
  brandName        String
  brandNormalized  String
  sku              String
  normalizedSku    String
  title            String
  subcategory      String?
  description      String?
  imageUrl         String?
  aliasesJson      Json             @default("[]")
  source           PartMasterSource @default(ADMIN)
  status           PartMasterStatus @default(ACTIVE)
  createdByUserId  String?
  createdBy        User?            @relation("PartMasterCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  skus               PartSku[]
  fitmentReports     FitmentReport[]
  fitmentConfidences FitmentConfidence[]
  aliases            PartAlias[]

  @@unique([normalizedSku, brandNormalized])
  @@index([brandNormalized])
  @@index([status])
  @@map("part_masters")
}

model PartSku {
  id            String  @id @default(cuid())
  seedKey       String? @unique
  partMasterId  String?
  partMaster    PartMaster? @relation(fields: [partMasterId], references: [id], onDelete: Restrict)
  primaryNodeId String?
  primaryNode   Node?   @relation("PartSkuPrimaryNode", fields: [primaryNodeId], references: [id], onDelete: SetNull)

  brandName     String
  canonicalName String
  partType      String

  description String?
  category    String?

  priceAmount Decimal? @db.Decimal(12, 2)
  currency    String?
  sourceUrl   String?

  isOem    Boolean @default(false)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partNumbers   PartNumber[]
  nodeLinks     PartSkuNodeLink[]
  fitments      PartFitment[]
  offers        PartOffer[]
  wishlistItems PartWishlistItem[]

  @@index([partMasterId])
  @@index([primaryNodeId])
  @@index([brandName])
  @@index([partType])
  @@index([isActive])
  @@map("part_skus")
}

model PartNumber {
  id    String  @id @default(cuid())
  skuId String
  sku   PartSku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  number           String
  normalizedNumber String
  numberType       String
  brandName        String?

  createdAt DateTime @default(now())

  @@unique([skuId, normalizedNumber, numberType])
  @@index([skuId])
  @@index([normalizedNumber])
  @@map("part_numbers")
}

model PartSkuNodeLink {
  id    String  @id @default(cuid())
  skuId String
  sku   PartSku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Restrict)

  relationType String
  confidence   Int    @default(80)

  createdAt DateTime @default(now())

  @@unique([skuId, nodeId, relationType])
  @@index([skuId])
  @@index([nodeId])
  @@map("part_sku_node_links")
}

model PartFitment {
  id    String  @id @default(cuid())
  skuId String
  sku   PartSku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  brandId        String?
  modelId        String?
  modelVariantId String?

  yearFrom Int?
  yearTo   Int?

  market     String?
  engineCode String?
  vinFrom    String?
  vinTo      String?

  fitmentType String?
  confidence  Int     @default(80)
  note        String?

  createdAt DateTime @default(now())

  @@index([skuId])
  @@index([brandId])
  @@index([modelId])
  @@index([modelVariantId])
  @@map("part_fitments")
}

model PartOffer {
  id String @id @default(cuid())

  skuId String?
  sku   PartSku? @relation(fields: [skuId], references: [id], onDelete: SetNull)

  sourceName      String
  externalOfferId String?
  title           String
  url             String?

  priceAmount  Decimal? @db.Decimal(12, 2)
  currency     String?
  availability String?

  sellerName  String?
  rawBrand    String?
  rawArticle  String?
  rawDataJson Json?

  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([skuId])
  @@index([sourceName])
  @@index([externalOfferId])
  @@map("part_offers")
}

model PartWishlistItem {
  id         String                 @id @default(cuid())
  vehicleId  String
  nodeId     String?
  skuId      String?
  title      String
  quantity   Int                    @default(1)
  status     PartWishlistItemStatus @default(NEEDED)
  /** NEEDED≈PLANNED, ORDERED/BOUGHT≈PURCHASED, INSTALLED per spec §8. */
  source     PartWishlistItemSource @default(RECOMMENDATION)
  comment    String?
  costAmount Float?
  currency   String?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  node         Node?         @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  sku          PartSku?      @relation(fields: [skuId], references: [id], onDelete: SetNull)
  expenseItems ExpenseItem[]

  @@index([vehicleId])
  @@index([nodeId])
  @@index([skuId])
  @@index([status])
  @@index([source])
  @@map("part_wishlist_items")
}

model FitmentReport {
  id                    String                       @id @default(cuid())
  partMasterId          String
  partMaster            PartMaster                   @relation(fields: [partMasterId], references: [id], onDelete: Cascade)
  vehicleId             String
  vehicle               Vehicle                      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  modelVariantId        String
  modelVariant          ModelVariant                 @relation(fields: [modelVariantId], references: [id], onDelete: Cascade)
  nodeId                String
  node                  Node                         @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  fitmentResult         FitmentReportResult
  installationStatus    FitmentInstallationStatus
  modificationRequired  Boolean                      @default(false)
  modificationDetails   String?
  comment               String?
  installedAtMileage    Int?
  installedAtHours      Int?
  rideProfileSnapshot   Json?
  rating                Int?
  serviceEventId        String?
  serviceEvent          ServiceEvent?                @relation(fields: [serviceEventId], references: [id], onDelete: SetNull)
  moderationStatus      FitmentReportModerationStatus @default(PENDING)
  createdByUserId       String
  createdBy             User                         @relation("FitmentReportCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  evidence FitmentEvidence[]
  votes    FitmentVote[]

  @@index([partMasterId, modelVariantId, nodeId])
  @@index([vehicleId])
  @@index([moderationStatus])
  @@index([createdByUserId])
