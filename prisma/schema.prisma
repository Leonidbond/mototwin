generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  TRIAL
}

enum UsageType {
  CITY
  HIGHWAY
  MIXED
  OFFROAD
}

enum RidingStyle {
  CALM
  ACTIVE
  AGGRESSIVE
}

enum LoadType {
  SOLO
  PASSENGER
  LUGGAGE
  PASSENGER_LUGGAGE
}

enum UsageIntensity {
  LOW
  MEDIUM
  HIGH
}

enum TopNodeStatus {
  OK
  SOON
  OVERDUE
  RECENTLY_REPLACED
}

enum NodeStatus {
  OK
  SOON
  OVERDUE
  RECENTLY_REPLACED
}

enum MaintenanceTriggerMode {
  WHICHEVER_COMES_FIRST
  ANY
  ALL
}

enum ServiceEventKind {
  SERVICE
  STATE_UPDATE
}

enum PartWishlistItemStatus {
  NEEDED
  ORDERED
  BOUGHT
  INSTALLED
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  subscription  Subscription?
  vehicles      Vehicle[]

  @@map("users")
}

model Subscription {
  id         String              @id @default(cuid())
  userId     String              @unique
  planType   PlanType            @default(FREE)
  status     SubscriptionStatus  @default(ACTIVE)
  startedAt  DateTime            @default(now())
  endsAt     DateTime?

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())

  models    Model[]
  vehicles  Vehicle[]

  @@map("brands")
}

model Model {
  id        String         @id @default(cuid())
  brandId   String
  name      String
  slug      String
  createdAt DateTime       @default(now())

  brand     Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  variants  ModelVariant[]
  vehicles  Vehicle[]

  @@unique([brandId, slug])
  @@map("models")
}

model ModelVariant {
  id             String    @id @default(cuid())
  modelId        String
  year           Int
  generation     String?
  versionName    String
  market         String?
  engineType     String?
  coolingType    String?
  wheelSizes     String?
  brakeSystem    String?
  chainPitch     String?
  stockSprockets String?
  createdAt      DateTime  @default(now())

  model          Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  vehicles       Vehicle[]

  @@index([modelId, year])
  @@map("model_variants")
}

model Vehicle {
  id             String       @id @default(cuid())
  userId         String
  brandId        String
  modelId        String
  modelVariantId String
  nickname       String?
  vin            String?
  odometer       Int          @default(0)
  engineHours    Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand          Brand        @relation(fields: [brandId], references: [id], onDelete: Restrict)
  model          Model        @relation(fields: [modelId], references: [id], onDelete: Restrict)
  modelVariant   ModelVariant @relation(fields: [modelVariantId], references: [id], onDelete: Restrict)
  rideProfile         RideProfile?
  serviceEvents       ServiceEvent[]
  topNodeStates       TopNodeState[]
  nodeStates          NodeState[]
  partWishlistItems   PartWishlistItem[]

  @@index([userId])
  @@index([brandId, modelId, modelVariantId])
  @@map("vehicles")
}

model ServiceEvent {
  id                 String   @id @default(cuid())
  vehicleId          String
  nodeId             String
  eventKind          ServiceEventKind @default(SERVICE)
  eventDate          DateTime
  odometer           Int
  engineHours        Int?
  serviceType        String
  installedPartsJson Json?
  costAmount         Float?
  currency           String?
  comment            String?
  createdAt          DateTime @default(now())

  vehicle            Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  node               Node     @relation(fields: [nodeId], references: [id], onDelete: Restrict)

  @@index([vehicleId])
  @@index([nodeId])
  @@map("service_events")
}

model Node {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  parentId      String?
  level         Int
  displayOrder  Int
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())

  parent        Node?          @relation("NodeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      Node[]         @relation("NodeHierarchy")
  serviceEvents       ServiceEvent[]
  topNodeStates       TopNodeState[]
  nodeStates          NodeState[]
  maintenanceRule   NodeMaintenanceRule?
  partWishlistItems   PartWishlistItem[]
  partSkusPrimary     PartSku[]          @relation("PartSkuPrimaryNode")
  partSkuNodeLinks    PartSkuNodeLink[]

  @@index([parentId])
  @@map("nodes")
}

model PartSku {
  id            String    @id @default(cuid())
  seedKey       String?   @unique
  primaryNodeId String?
  primaryNode   Node?     @relation("PartSkuPrimaryNode", fields: [primaryNodeId], references: [id], onDelete: SetNull)

  brandName     String
  canonicalName String
  partType      String

  description   String?
  category      String?

  priceAmount   Decimal?  @db.Decimal(12, 2)
  currency      String?
  sourceUrl     String?

  isOem         Boolean   @default(false)
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  partNumbers   PartNumber[]
  nodeLinks     PartSkuNodeLink[]
  fitments      PartFitment[]
  offers        PartOffer[]
  wishlistItems PartWishlistItem[]

  @@index([primaryNodeId])
  @@index([brandName])
  @@index([partType])
  @@index([isActive])
  @@map("part_skus")
}

model PartNumber {
  id               String   @id @default(cuid())
  skuId            String
  sku              PartSku  @relation(fields: [skuId], references: [id], onDelete: Cascade)

  number           String
  normalizedNumber String
  numberType       String
  brandName        String?

  createdAt        DateTime @default(now())

  @@index([skuId])
  @@index([normalizedNumber])
  @@unique([skuId, normalizedNumber, numberType])
  @@map("part_numbers")
}

model PartSkuNodeLink {
  id           String   @id @default(cuid())
  skuId        String
  sku          PartSku  @relation(fields: [skuId], references: [id], onDelete: Cascade)

  nodeId       String
  node         Node     @relation(fields: [nodeId], references: [id], onDelete: Restrict)

  relationType String
  confidence   Int      @default(80)

  createdAt    DateTime @default(now())

  @@index([skuId])
  @@index([nodeId])
  @@unique([skuId, nodeId, relationType])
  @@map("part_sku_node_links")
}

model PartFitment {
  id             String   @id @default(cuid())
  skuId          String
  sku            PartSku  @relation(fields: [skuId], references: [id], onDelete: Cascade)

  brandId        String?
  modelId        String?
  modelVariantId String?

  yearFrom       Int?
  yearTo         Int?

  market         String?
  engineCode     String?
  vinFrom        String?
  vinTo          String?

  fitmentType    String?
  confidence     Int      @default(80)
  note           String?

  createdAt      DateTime @default(now())

  @@index([skuId])
  @@index([brandId])
  @@index([modelId])
  @@index([modelVariantId])
  @@map("part_fitments")
}

model PartOffer {
  id              String   @id @default(cuid())

  skuId           String?
  sku             PartSku? @relation(fields: [skuId], references: [id], onDelete: SetNull)

  sourceName      String
  externalOfferId String?
  title           String
  url             String?

  priceAmount     Decimal? @db.Decimal(12, 2)
  currency        String?
  availability    String?

  sellerName      String?
  rawBrand        String?
  rawArticle      String?
  rawDataJson     Json?

  lastSeenAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([skuId])
  @@index([sourceName])
  @@index([externalOfferId])
  @@map("part_offers")
}

model PartWishlistItem {
  id        String                  @id @default(cuid())
  vehicleId String
  nodeId    String?
  skuId     String?
  title     String
  quantity  Int                     @default(1)
  status    PartWishlistItemStatus  @default(NEEDED)
  comment   String?
  costAmount Float?
  currency   String?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  vehicle   Vehicle                 @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  node      Node?                   @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  sku       PartSku?                @relation(fields: [skuId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([nodeId])
  @@index([skuId])
  @@index([status])
  @@map("part_wishlist_items")
}

model TopNodeState {
  id                 String        @id @default(cuid())
  vehicleId          String
  nodeId             String
  status             TopNodeStatus
  lastServiceEventId String?
  note               String?
  updatedAt          DateTime      @updatedAt
  createdAt          DateTime      @default(now())

  vehicle            Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  node               Node          @relation(fields: [nodeId], references: [id], onDelete: Restrict)

  @@index([vehicleId])
  @@index([nodeId])
  @@unique([vehicleId, nodeId])
  @@map("top_node_states")
}

model NodeState {
  id                 String     @id @default(cuid())
  vehicleId          String
  nodeId             String
  status             NodeStatus
  lastServiceEventId String?
  note               String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  vehicle            Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  node               Node       @relation(fields: [nodeId], references: [id], onDelete: Restrict)

  @@index([vehicleId])
  @@index([nodeId])
  @@unique([vehicleId, nodeId])
  @@map("node_states")
}

model NodeMaintenanceRule {
  id            String                 @id @default(cuid())
  nodeId        String
  intervalKm    Int?
  intervalHours Int?
  intervalDays  Int?
  triggerMode   MaintenanceTriggerMode
  warningKm     Int?
  warningHours  Int?
  warningDays   Int?
  isActive      Boolean                @default(true)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  node          Node                   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@unique([nodeId])
  @@map("node_maintenance_rules")
}

model RideProfile {
  id             String          @id @default(cuid())
  vehicleId      String          @unique
  usageType      UsageType
  ridingStyle    RidingStyle
  loadType       LoadType
  usageIntensity UsageIntensity
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("ride_profiles")
}