generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELED
  TRIAL
}

enum UsageType {
  CITY
  HIGHWAY
  MIXED
  OFFROAD
}

enum RidingStyle {
  CALM
  ACTIVE
  AGGRESSIVE
}

enum LoadType {
  SOLO
  PASSENGER
  LUGGAGE
  PASSENGER_LUGGAGE
}

enum UsageIntensity {
  LOW
  MEDIUM
  HIGH
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  passwordHash  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  subscription  Subscription?
  vehicles      Vehicle[]

  @@map("users")
}

model Subscription {
  id         String              @id @default(cuid())
  userId     String              @unique
  planType   PlanType            @default(FREE)
  status     SubscriptionStatus  @default(ACTIVE)
  startedAt  DateTime            @default(now())
  endsAt     DateTime?

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())

  models    Model[]
  vehicles  Vehicle[]

  @@map("brands")
}

model Model {
  id        String         @id @default(cuid())
  brandId   String
  name      String
  slug      String
  createdAt DateTime       @default(now())

  brand     Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  variants  ModelVariant[]
  vehicles  Vehicle[]

  @@unique([brandId, slug])
  @@map("models")
}

model ModelVariant {
  id             String    @id @default(cuid())
  modelId        String
  year           Int
  generation     String?
  versionName    String
  market         String?
  engineType     String?
  coolingType    String?
  wheelSizes     String?
  brakeSystem    String?
  chainPitch     String?
  stockSprockets String?
  createdAt      DateTime  @default(now())

  model          Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  vehicles       Vehicle[]

  @@index([modelId, year])
  @@map("model_variants")
}

model Vehicle {
  id             String       @id @default(cuid())
  userId         String
  brandId        String
  modelId        String
  modelVariantId String
  nickname       String?
  vin            String?
  odometer       Int          @default(0)
  engineHours    Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  brand          Brand        @relation(fields: [brandId], references: [id], onDelete: Restrict)
  model          Model        @relation(fields: [modelId], references: [id], onDelete: Restrict)
  modelVariant   ModelVariant @relation(fields: [modelVariantId], references: [id], onDelete: Restrict)
  rideProfile    RideProfile?

  @@index([userId])
  @@index([brandId, modelId, modelVariantId])
  @@map("vehicles")
}

model RideProfile {
  id             String          @id @default(cuid())
  vehicleId      String          @unique
  usageType      UsageType
  ridingStyle    RidingStyle
  loadType       LoadType
  usageIntensity UsageIntensity
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("ride_profiles")
}