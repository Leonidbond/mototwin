{
  "name": "mototwin",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:motorcycle": "tsx scripts/seed-motorcycle-master.ts",
    "qa:service-bundle-advanced-smoke": "tsx scripts/qa-service-bundle-advanced-smoke.ts",
    "qa:service-event-full-smoke": "tsx scripts/qa-service-event-full-smoke.ts",
    "qa:service-log-web-routes-smoke": "tsx scripts/qa-service-log-web-routes-smoke.ts",
    "qa:notifications-smoke": "tsx scripts/qa-notifications-smoke.ts",
    "qa:auth-smoke": "tsx scripts/qa-auth-smoke.ts",
    "cron:notifications": "tsx scripts/cron-recalculate-all-users.ts",
    "mobile:dev": "npm run dev --workspace @mototwin/app",
    "mobile:dev:lan": "npm run dev:lan --workspace @mototwin/app",
    "mobile:dev:usb": "npm run dev:localhost --workspace @mototwin/app",
    "mobile:adb:reverse": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:3000 tcp:3000",
    "mobile:dev:tunnel": "npm run dev:tunnel --workspace @mototwin/app",
    "mobile:android": "npm run android --workspace @mototwin/app",
    "mobile:ios": "npm run ios --workspace @mototwin/app",
    "mobile:web": "npm run web --workspace @mototwin/app",
    "icons:audit-node-tree": "tsx scripts/audit-node-tree-icons.ts",
    "icons:rebuild-node-tree-from-design": "node scripts/sync-node-icons-from-slices.mjs && node scripts/generate-node-tree-icons-ts.mjs",
    "expo": "npm exec --workspace=@mototwin/app -- expo"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@iminside/react-yandex-maps": "^1.2.7",
    "@mototwin/api-client": "*",
    "@mototwin/design-tokens": "*",
    "@mototwin/domain": "*",
    "@mototwin/icons": "*",
    "@mototwin/types": "*",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "whatwg-fetch": "^3.6.20",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "expo-router": "~6.0.23",
    "tailwindcss": "^4",
    "tesseract.js": "^5.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "overrides": {
    "expo": "54.0.33",
    "expo-modules-core": "3.0.29"
  }
}
