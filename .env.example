# Скопируйте в `.env` в корне репозитория (файл в .gitignore).
# Next.js и Prisma читают переменные отсюда при `npm run dev`, миграциях, seed.
#
# Обязательно:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mototwin?schema=public"
#
# Auth (обязательно на production VPS):
# AUTH_SECRET="openssl rand -base64 32"
# MOTOTWIN_BETA_ALLOWED_EMAILS="you@example.com,beta-tester@example.com"
# AUTH_BASE_URL="https://mototwin.online"
# NEXTAUTH_URL="https://mototwin.online"
#
# Auth.js / OAuth (web):
# AUTH_GOOGLE_CLIENT_ID=""
# AUTH_GOOGLE_CLIENT_SECRET=""
# AUTH_APPLE_CLIENT_ID=""
# AUTH_APPLE_CLIENT_SECRET=""
# YANDEX_CLIENT_ID=""
# YANDEX_CLIENT_SECRET=""
#
# Mobile OAuth token verification:
# GOOGLE_OAUTH_CLIENT_ID="" # Web client ID (idToken audience for Expo webClientId flow)
# GOOGLE_ANDROID_OAUTH_CLIENT_ID="" # Android OAuth client ID (native Google Sign-In idToken aud)
# GOOGLE_IOS_OAUTH_CLIENT_ID="" # iOS OAuth client ID
# GOOGLE_OAUTH_CLIENT_IDS="" # Optional comma-separated list of extra allowed Google audiences
# APPLE_CLIENT_ID=""        # Service ID / client id Apple Sign In
# YANDEX_OAUTH_CLIENT_ID="" # client_id мобильного приложения Яндекс OAuth — проверяется
                              # против токена через https://oauth.yandex.ru/introspect.
                              # Если не задан, /api/auth/oauth/mobile вернёт 500
                              # YANDEX_CONFIG_MISSING для провайдера yandex.
#
# Password recovery email:
# RESEND_API_KEY=""
# AUTH_EMAIL_FROM="MotoTwin <no-reply@example.com>"
#
# Auth audit log retention / alerting (MT-SEC-055, optional):
# AUTH_AUDIT_RETENTION_DAYS="90"
# AUTH_AUDIT_ALERT_FAILED_LOGIN_THRESHOLD="10"
# AUTH_AUDIT_ALERT_WINDOW_MS="60000"
#
# Опционально (локальная разработка, dev user switcher в UI / API):
# MOTOTWIN_ENABLE_DEV_USER_SWITCHER=true
#
# Опционально (web: поле «Место установки» на /vehicles/[id]/service-events/* — кнопка «На карте»):
# Кабинет: https://developer.tech.yandex.ru/
#   NEXT_PUBLIC_YANDEX_MAPS_API_KEY — ключ «JavaScript API» (карта на модалке «На карте»)
#   YANDEX_GEOCODER_API_KEY — ключ «HTTP Геокодер» (поиск адресов и reverse в /api/geocode)
#   YANDEX_GEOSUGGEST_API_KEY — ключ «Геосаджест» (серверный поиск; нужен Referer, см. ниже)
#   NEXT_PUBLIC_YANDEX_SUGGEST_API_KEY — тот же ключ Geosuggest для поиска из браузера (рекомендуется)
#   YANDEX_GEOSUGGEST_REFERER — Referer для серверных запросов, напр. http://localhost:3000/
# В кабинете для ключа Geosuggest: HTTP Referrer = localhost (и mototwin.online для prod) или без ограничений на dev.
# Ключ активируется до ~15 минут после создания.
# После добавления перезапустите npm run dev. Подробнее: docs/web-service-event-form.md §5.1
# NEXT_PUBLIC_YANDEX_MAPS_API_KEY="your-yandex-maps-js-api-key"
# YANDEX_GEOCODER_API_KEY="your-yandex-http-geocoder-api-key"
# YANDEX_GEOSUGGEST_API_KEY="your-yandex-geosuggest-api-key"
# NEXT_PUBLIC_YANDEX_SUGGEST_API_KEY="your-yandex-geosuggest-api-key"
# YANDEX_GEOSUGGEST_REFERER="http://localhost:3000/"
#
# Клиент Expo (только override URL API) — отдельно, см. apps/app/.env.example
