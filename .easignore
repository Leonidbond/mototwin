# EAS uploads from monorepo root — exclude heavy dirs (npm ci runs on server).
.next
node_modules
.git
.cursor
.venv-tools
.venv-icon
coverage
mototwin.dump
*.tsbuildinfo
**/*.log

# Android local build cache (rebuilt on EAS)
apps/app/android/.gradle
apps/app/android/.cxx
apps/app/android/**/build

# iOS — Pods reinstalled by EAS via `pod install`; source kept for future iOS builds
apps/app/ios/Pods
apps/app/ios/build

# Web/backend — not used by mobile EAS build (prisma/ kept for postinstall).
# Mobile bundles repo-root src/node-tree-icons.ts and images/* — do not exclude wholesale.
/src/*
!/src/node-tree-icons.ts
public
# Unused heavy image trees (mobile uses images/node-tree-icons/nodes, Motocycles, etc.)
/images/node-tree-icons-new/**
/images/node-tree-icons/from-design/**
docs
scripts
deploy
data

auth
.env
.env.*
