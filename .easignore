# EAS uploads from monorepo root — exclude heavy dirs (npm ci runs on server).
.next
node_modules
.git
.cursor
.venv-tools
.venv-icon
coverage
mototwin.dump
*.tsbuildinfo
**/*.log

# Android local build cache (rebuilt on EAS)
apps/app/android/.gradle
apps/app/android/.cxx
apps/app/android/**/build

# iOS — Pods reinstalled by EAS via `pod install`; source kept for future iOS builds
apps/app/ios/Pods
apps/app/ios/build

# Web/backend — not used by mobile EAS build (prisma/ kept for postinstall)
/src
public
images
docs
scripts
deploy
data

auth
.env
.env.*
